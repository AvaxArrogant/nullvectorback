PULSECHAIN_RPC_URL=https://rpc.pulsechain.com
PULSECHAIN_EXPLORER_API=https://scan.pulsechain.com/api
PULSESHIELD_DATA_DIR=.data
PULSESHIELD_ADMIN_KEY=change-this-long-private-admin-key
PULSESHIELD_ROOT_ADMIN=0x85E6cC88F3055b589eb1d4030863be2CFcc0763E
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional feedback email relay. Hostinger Email typically uses smtp.hostinger.com:465.
FEEDBACK_TO_EMAIL=contact@pulseshield.io
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@pulseshield.io
SMTP_PASS=
SMTP_FROM=contact@pulseshield.io

# Optional if you enable Ethereum scans in production.
# ETHEREUM_RPC_URL=https://ethereum-rpc.publicnode.com
# ETHERSCAN_API_KEY=
